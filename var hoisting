<!DOCTYPE html>
<html>
<head>
    <title>Hoisting Demo</title>

    <style>

        body{
            font-family: Arial;
            background-color: lightgray;
            text-align: center;
            padding: 20px;
        }

        .box{
            background-color: white;
            width: 500px;
            margin: auto;
            padding: 20px;
            border: 1px solid black;
        }

        button{
            padding: 10px;
            margin: 5px;
        }

        #output{
            margin-top: 20px;
            background-color: #eeeeee;
            padding: 10px;
        }

    </style>
</head>

<body>

<div class="box">

    <h1>Hoisting Demo</h1>

    <button onclick="showVar()">VAR</button>

    <button onclick="showLet()">LET</button>

    <button onclick="showConst()">CONST</button>

    <button onclick="showFunction()">FUNCTION</button>

    <div id="output"></div>

</div>

<script>

function showVar() {

    var text = "VAR Example <br>";

    text += a + "<br>";

    var a = 10;

    text += "Value = " + a;

    document.getElementById("output").innerHTML = text;
}

function showLet() {

    let b = 20;

    document.getElementById("output").innerHTML =
    "LET Value = " + b;
}

function showConst() {

    const c = 30;

    document.getElementById("output").innerHTML =
    "CONST Value = " + c;
}

function showFunction() {

    hello();

    function hello() {

        document.getElementById("output").innerHTML =
        "Function Hoisting Works";
    }
}

</script>

</body>
</html>
